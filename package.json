{
  "name": "termi",
  "version": "1.0.0",
  "private": true,
  "description": "Secure server management PWA - SSH, SCP, RDP, VNC from your browser",
  "license": "MIT",
  "author": "Termi Contributors",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:gateway": "npm run dev --workspace=apps/gateway",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:gateway\"",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/gateway",
    "start": "npm run start --workspace=apps/web",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "db:push": "npm run db:push --workspace=apps/web",
    "db:migrate": "npm run db:migrate --workspace=apps/web",
    "db:generate": "npm run db:generate --workspace=apps/web",
    "db:seed": "npm run db:seed --workspace=apps/web",
    "db:studio": "npm run db:studio --workspace=apps/web",
    "electron:dev": "concurrently \"npm run dev\" \"npm run dev:gateway\" \"sleep 5 && npm run start --workspace=apps/electron\"",
    "electron:build": "bash scripts/electron-build.sh",
    "electron:build:mac": "bash scripts/electron-build.sh --mac",
    "electron:build:win": "bash scripts/electron-build.sh --win",
    "electron:build:linux": "bash scripts/electron-build.sh --linux"
  },
  "overrides": {
    "proper-lockfile": {
      "signal-exit": "^3.0.0"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
