# ============================================================================
# Termi — Environment Variables
# Copy this file to .env.local and fill in the values.
# ============================================================================

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/termi"

# ── Session Encryption ───────────────────────────────────────────────────────
# REQUIRED: Must be at least 32 characters. Generate with:
#   openssl rand -base64 32
SESSION_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ── Credential Encryption ────────────────────────────────────────────────────
# REQUIRED: AES-256 key for encrypting server credentials at rest. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY="change-me-generate-with-openssl-rand-base64-32"

# ── Gateway JWT (JWE) ─────────────────────────────────────────────────────────
# REQUIRED: Shared secret between web app and gateway for encrypted connection tokens.
# Generate with: openssl rand -base64 32
GATEWAY_JWT_SECRET="change-me-generate-with-openssl-rand-base64-32"

# ── Gateway URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL="http://localhost:4000"

# ── App URL (for email links) ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Optional: If not set, email OTPs and verification links are logged to console (dev mode).
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"          # true for port 465
SMTP_USER="your@email.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM='"Termi" <noreply@termi.app>'

# ── Security ──────────────────────────────────────────────────────────────────
# Set to "true" to allow connections to private/internal IP addresses.
# Useful for self-hosted / home-lab deployments.
# WARNING: Do NOT enable in public-facing deployments.
ALLOW_PRIVATE_NETWORKS="false"

