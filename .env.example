# Termi Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================

# Full connection URL for your external PostgreSQL database.
# The app reads this directly — no local 'db' service is bundled.
# Example: postgresql://user:password@your-db-host:5432/termi?sslmode=require
DATABASE_URL=postgresql://termi:your-secure-password-here@your-db-host:5432/termi

# =============================================================================
# SECURITY KEYS (REQUIRED - Generate unique values!)
# =============================================================================

# Session encryption key (min 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-min-32-characters

# Database encryption key for credentials (AES-256)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-generate-with-openssl

# JWT secret for gateway communication
# Generate with: openssl rand -base64 32
GATEWAY_JWT_SECRET=your-gateway-jwt-secret

# =============================================================================
# SERVICE URLS
# =============================================================================

# WebSocket gateway URL (for browser to connect)
# In production, use wss:// with proper domain
GATEWAY_URL=ws://localhost:8080
NEXT_PUBLIC_GATEWAY_URL=ws://localhost:8080

# =============================================================================
# PORTS
# =============================================================================

# Web application port
WEB_PORT=3000

# Gateway port
GATEWAY_PORT=8080

# =============================================================================
# OPTIONAL
# =============================================================================

# Enable debug logging (development only)
# DEBUG=true

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1


# guacd
GUACD_HOST=guacd
GUACD_PORT=4822

# =============================================================================
# SMTP (for alert emails)
# =============================================================================

# SMTP server configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Termi Alerts <alerts@example.com>"

# =============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# =============================================================================

# Generate VAPID keys with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@example.com

# Public URL for email alert links
# NEXT_PUBLIC_APP_URL=https://your-domain.com